generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Player {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  passwordHash String
  salt         String
  name         String
  avatar       String?
  avatarImage  String?
  flag         String?
  teamName     String
  teamLogo     String?
  bio                  String?
  nationality          String?
  favoriteClub         String?
  favoriteCompetition  String?
  coverBanner          String?
  lastActive           DateTime?
  lastReadNotificationAt DateTime?
  onlineStatus         String    @default("online")
  assists              Int       @default(0)
  createdAt    DateTime  @default(now())

  // Relations
  homeMatches Match[] @relation("HomeMatches")
  awayMatches Match[] @relation("AwayMatches")
  trophies    Trophy[] @relation("PlayerTrophies")
  
  // Season Relations (for history)
  wonSeasons     Season[] @relation("SeasonChampion")
  runnerUpSeasons Season[] @relation("SeasonRunnerUp")
  thirdSeasons    Season[] @relation("SeasonThirdPlace")
  mvpSeasons      Season[] @relation("SeasonMVP")
}

model Season {
  id         String    @id @default(cuid())
  name       String
  type       String    @default("League") // "League", "League + Playoffs"
  status     String    @default("Live") // "Live", "Archived"
  isArchived Boolean   @default(false)
  fixtures   Json?     // Stores the generated schedule arrays
  startDate  DateTime?
  createdAt  DateTime  @default(now())
  completedAt DateTime?

  championId String?
  champion   Player?   @relation("SeasonChampion", fields: [championId], references: [id])
  
  runnerUpId String?
  runnerUp   Player?   @relation("SeasonRunnerUp", fields: [runnerUpId], references: [id])
  
  thirdId    String?
  third      Player?   @relation("SeasonThirdPlace", fields: [thirdId], references: [id])
  
  mvpId      String?
  mvp        Player?   @relation("SeasonMVP", fields: [mvpId], references: [id])

  matches Match[]
}

model Match {
  id           String   @id @default(cuid())
  seasonId     String
  season       Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  
  round        String // "league", "semiA", "semiB", "challenger", "final"
  
  homeId       String
  home         Player   @relation("HomeMatches", fields: [homeId], references: [id])
  
  awayId       String
  away         Player   @relation("AwayMatches", fields: [awayId], references: [id])
  
  homeScore    Int?
  awayScore    Int?
  
  status       String   @default("scheduled") // "scheduled", "live", "completed"
  scheduledAt  DateTime?
  completedAt  DateTime?
  label        String?
  
  liveState    Json?    // Stores current phase, time, paused state, and penalties
  wentToExtra  Boolean  @default(false)
  decisive     Boolean  @default(false) // Whether a winner is required (knockouts)
  
  penaltyHome  Int?
  penaltyAway  Int?
  penaltyWinner String? // "home" or "away"
}

model Notification {
  id        String   @id @default(cuid())
  text      String
  type      String   @default("info")
  createdAt DateTime @default(now())
}

model Trophy {
  id          String   @id @default(cuid())
  playerId    String
  player      Player   @relation("PlayerTrophies", fields: [playerId], references: [id], onDelete: Cascade)
  title       String
  season      String
  description String?
  icon        String?  // emoji or URL
  createdAt   DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
}

model TrophyTemplate {
  id          String   @id @default(cuid())
  name        String
  icon        String   // emoji or /assets/trophies/... path
  description String?
  createdAt   DateTime @default(now())
}
